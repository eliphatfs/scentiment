// Nison Candlestick Patterns — full pattern suite with multi-scale trend,
// confirmation flow, strength scoring, and multi-order pivots.
//
// Ported from the Python scentiment library.
// References:
//   Steve Nison — Japanese Candlestick Charting Techniques
//   Adam Grimes — The Art and Science of Technical Analysis
//
//@version=6
indicator("Nison Candlestick Patterns", overlay=true,
     max_labels_count=500, max_lines_count=200, max_bars_back=500)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

// ── Display ──────────────────────────────────────────────────────────
i_showPatterns   = input.bool(true,  "Show Pattern Labels",         group="Display")
i_showPivots     = input.bool(true,  "Show Pivots",                 group="Display")
i_showTable      = input.bool(true,  "Show Trend Table",            group="Display")
i_showConf       = input.bool(true,  "Show Confirmation Status",    group="Display")

// ── Pivot detection (Grimes higher-order definition) ────────────────
// Order 1: local high/low vs immediate neighbors (configurable window).
// Order 2: order-1 pivot whose value exceeds both adjacent order-1 pivots.
// Order 3: order-2 pivot whose value exceeds both adjacent order-2 pivots.
// No window-size parameters for orders 2/3 — they are defined purely by
// the sequence of lower-order pivots.
i_pvLeft   = input.int(1,  "Pivot — Left bars",  minval=1, group="Pivots")
i_pvRight  = input.int(1,  "Pivot — Right bars", minval=1, group="Pivots")

// ── Shape thresholds ─────────────────────────────────────────────────
i_dojiThr        = input.float(0.1,   "Doji Threshold",             step=0.01,   group="Shape")
i_shadowMult     = input.float(2.0,   "Shadow Multiplier (hammer/star)", step=0.1, group="Shape")
i_upperShadRatio = input.float(0.1,   "Max Minor Shadow Ratio",     step=0.01,   group="Shape")
i_penetration    = input.float(0.5,   "Penetration (dark cloud/piercing/star)", step=0.05, group="Shape")
i_smallBody      = input.float(0.3,   "Small Body Ratio",           step=0.05,   group="Shape")
i_longBody       = input.float(0.6,   "Long Body Ratio",            step=0.05,   group="Shape")
i_beltShadow     = input.float(0.05,  "Belt Hold Shadow Ratio",     step=0.01,   group="Shape")
i_crowsShadow    = input.float(0.1,   "3 Black Crows Shadow Ratio", step=0.01,   group="Shape")
i_graveLower     = input.float(0.05,  "Gravestone Lower Shadow Ratio", step=0.01, group="Shape")
i_graveUpper     = input.float(0.5,   "Gravestone Upper Shadow Ratio", step=0.05, group="Shape")
i_llDojiShadow   = input.float(0.3,   "Long-legged Doji Shadow Ratio", step=0.05, group="Shape")
i_rikCenter      = input.float(0.25,  "Rickshaw Man Center Tolerance",  step=0.05, group="Shape")

// ── Price matching ───────────────────────────────────────────────────
i_matchTol       = input.float(0.001, "Match Tolerance (tweezers/cntratk/sep)", step=0.0001, group="Matching")
i_mtRiverTol     = input.float(0.003, "Three Mountains/Rivers Tolerance",       step=0.001,  group="Matching")
i_mtRiverLB      = input.int(30,      "Three Mountains/Rivers Lookback",                     group="Matching")

// ── Trend ────────────────────────────────────────────────────────────
i_trendLB        = input.int(5,  "Regression Lookback",    minval=2,  group="Trend")
i_bodyRunMin     = input.int(2,  "Body Run Min Bars",      minval=2,  group="Trend")
i_multiBarWin    = input.int(10, "Multi-bar Pattern Window", minval=3, group="Trend")

// ── Scoring ──────────────────────────────────────────────────────────
i_volWindow      = input.int(20, "Volume Avg Window",   minval=2,  group="Scoring")
i_trendScoreLB   = input.int(10, "Trend Score Lookback", minval=2, group="Scoring")


// ═══════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════

bodySize(i)    => math.abs(close[i] - open[i])
bodyTop(i)     => math.max(close[i], open[i])
bodyBot(i)     => math.min(close[i], open[i])
upperShad(i)   => high[i] - bodyTop(i)
lowerShad(i)   => bodyBot(i) - low[i]
candleRange(i) => high[i] - low[i]
isBullish(i)   => close[i] > open[i]
isBearish(i)   => close[i] < open[i]

isDoji(i) =>
    rng = candleRange(i)
    rng > 0 ? bodySize(i) <= i_dojiThr * rng : true

bodyRatio(i) =>
    rng = candleRange(i)
    rng > 0 ? bodySize(i) / rng : 0.0

isLongBody(i)  => bodyRatio(i) >= i_longBody
isSmallBody(i) => bodyRatio(i) <= i_smallBody


// ═══════════════════════════════════════════════════════════════════════════
// REGRESSION SLOPE
// ═══════════════════════════════════════════════════════════════════════════

regSlope(src, length) =>
    if bar_index < length - 1
        0.0
    else
        xMean = (length - 1) / 2.0
        xVar  = length * (length * length - 1) / 12.0
        sumY  = 0.0
        sumXY = 0.0
        for k = 0 to length - 1
            y = src[length - 1 - k]
            sumY  += y
            sumXY += k * y
        (sumXY - xMean * sumY) / xVar


// ═══════════════════════════════════════════════════════════════════════════
// PIVOTS (Grimes higher-order definition)
// ═══════════════════════════════════════════════════════════════════════════
// Order 1: ta.pivothigh/low with configurable left/right window.
// Order 2: among order-1 pivots, one whose value exceeds both adjacent
//          order-1 pivots of the same kind. Confirmed when the next
//          order-1 pivot arrives.
// Order 3: same logic applied to order-2 pivots.

ph1 = ta.pivothigh(high, i_pvLeft, i_pvRight)
pl1 = ta.pivotlow (low,  i_pvLeft, i_pvRight)

// ── Order-1 tracking arrays for higher-order computation ──────────────
var float[] ph1Vals = array.new_float(0)
var int[]   ph1Bars = array.new_int(0)
var float[] pl1Vals = array.new_float(0)
var int[]   pl1Bars = array.new_int(0)

int ph1Bar = bar_index - i_pvRight   // bar where the order-1 pivot sits
int pl1Bar = bar_index - i_pvRight

if not na(ph1)
    array.push(ph1Vals, ph1)
    array.push(ph1Bars, ph1Bar)
if not na(pl1)
    array.push(pl1Vals, pl1)
    array.push(pl1Bars, pl1Bar)

// ── Order-2: check second-to-last order-1 pivot ───────────────────────
// When a new order-1 PH arrives and we have ≥3, the second-to-last can
// be confirmed as order-2 if it's higher than both neighbors.
var float[] ph2Vals = array.new_float(0)
var int[]   ph2Bars = array.new_int(0)
var float[] pl2Vals = array.new_float(0)
var int[]   pl2Bars = array.new_int(0)

bool newPH2 = false
int  ph2Bar = 0
float ph2Val = na
bool newPL2 = false
int  pl2Bar = 0
float pl2Val = na

if not na(ph1) and array.size(ph1Vals) >= 3
    int sz = array.size(ph1Vals)
    float prev_ = array.get(ph1Vals, sz - 3)
    float mid_  = array.get(ph1Vals, sz - 2)
    float next_ = array.get(ph1Vals, sz - 1)
    if mid_ > prev_ and mid_ > next_
        newPH2 := true
        ph2Bar := array.get(ph1Bars, sz - 2)
        ph2Val := mid_
        array.push(ph2Vals, mid_)
        array.push(ph2Bars, ph2Bar)

if not na(pl1) and array.size(pl1Vals) >= 3
    int sz = array.size(pl1Vals)
    float prev_ = array.get(pl1Vals, sz - 3)
    float mid_  = array.get(pl1Vals, sz - 2)
    float next_ = array.get(pl1Vals, sz - 1)
    if mid_ < prev_ and mid_ < next_
        newPL2 := true
        pl2Bar := array.get(pl1Bars, sz - 2)
        pl2Val := mid_
        array.push(pl2Vals, mid_)
        array.push(pl2Bars, pl2Bar)

// ── Order-3: check second-to-last order-2 pivot ───────────────────────
bool newPH3 = false
int  ph3Bar = 0
bool newPL3 = false
int  pl3Bar = 0

if newPH2 and array.size(ph2Vals) >= 3
    int sz = array.size(ph2Vals)
    float prev_ = array.get(ph2Vals, sz - 3)
    float mid_  = array.get(ph2Vals, sz - 2)
    float next_ = array.get(ph2Vals, sz - 1)
    if mid_ > prev_ and mid_ > next_
        newPH3 := true
        ph3Bar := array.get(ph2Bars, sz - 2)

if newPL2 and array.size(pl2Vals) >= 3
    int sz = array.size(pl2Vals)
    float prev_ = array.get(pl2Vals, sz - 3)
    float mid_  = array.get(pl2Vals, sz - 2)
    float next_ = array.get(pl2Vals, sz - 1)
    if mid_ < prev_ and mid_ < next_
        newPL3 := true
        pl3Bar := array.get(pl2Bars, sz - 2)


// ═══════════════════════════════════════════════════════════════════════════
// TREND DETECTION
// ═══════════════════════════════════════════════════════════════════════════

// ── Body-run micro-trend (Nison) ─────────────────────────────────────
var int bodyRunCount = 0
var int bodyRunDir   = 0   // +1 bullish, -1 bearish

curDir = isBullish(0) ? 1 : isBearish(0) ? -1 : 0
if curDir == bodyRunDir and curDir != 0
    bodyRunCount += 1
else
    bodyRunCount := curDir != 0 ? 1 : 0
    bodyRunDir   := curDir

microTrend = bodyRunCount >= i_bodyRunMin ? (bodyRunDir == 1 ? 1 : -1) : 0

// ── Regression slope short-trend ─────────────────────────────────────
slope     = regSlope(close, i_trendLB)
shortTrend = slope > 0 ? 1 : slope < 0 ? -1 : 0

// ── Pivot-based trend (order 1 = medium, order 2 = long) ────────────
// Track last two pivot highs/lows for HH+HL / LH+LL detection.

var float lastPH1v  = na
var float prevPH1v  = na
var float lastPL1v  = na
var float prevPL1v  = na

if not na(ph1)
    prevPH1v := lastPH1v
    lastPH1v := ph1
if not na(pl1)
    prevPL1v := lastPL1v
    lastPL1v := pl1

mediumUp   = not na(prevPH1v) and not na(prevPL1v) and lastPH1v > prevPH1v and lastPL1v > prevPL1v
mediumDown = not na(prevPH1v) and not na(prevPL1v) and lastPH1v < prevPH1v and lastPL1v < prevPL1v
mediumTrend = mediumUp ? 1 : mediumDown ? -1 : 0

var float lastPH2v  = na
var float prevPH2v  = na
var float lastPL2v  = na
var float prevPL2v  = na

if newPH2
    prevPH2v := lastPH2v
    lastPH2v := ph2Val
if newPL2
    prevPL2v := lastPL2v
    lastPL2v := pl2Val

longUp   = not na(prevPH2v) and not na(prevPL2v) and lastPH2v > prevPH2v and lastPL2v > prevPL2v
longDown = not na(prevPH2v) and not na(prevPL2v) and lastPH2v < prevPH2v and lastPL2v < prevPL2v
longTrend = longUp ? 1 : longDown ? -1 : 0

// ── Effective trend (cascade: pivot → regression → body-run) ────────
effectiveTrend = mediumTrend != 0 ? mediumTrend : shortTrend != 0 ? shortTrend : microTrend

// Pre-compute trend lookbacks at global scope (Pine v6 requires consistent execution)
bool trendUp1  = effectiveTrend[1] ==  1
bool trendDn1  = effectiveTrend[1] == -1
bool trendUp2  = effectiveTrend[2] ==  1
bool trendDn2  = effectiveTrend[2] == -1
bool trendUp3  = effectiveTrend[3] ==  1
bool trendDn3  = effectiveTrend[3] == -1
bool trendUpMB = effectiveTrend[i_multiBarWin] ==  1
bool trendDnMB = effectiveTrend[i_multiBarWin] == -1


// ═══════════════════════════════════════════════════════════════════════════
// PATTERN DETECTION
// ═══════════════════════════════════════════════════════════════════════════

// Each pattern sets a bullish and/or bearish boolean.
// Trend context uses effectiveTrend shifted to the first bar of the pattern.

// ── Hammer (ch. 4) ───────────────────────────────────────────────────
hammerShape = candleRange(0) > 0
     and lowerShad(0) >= i_shadowMult * bodySize(0)
     and upperShad(0) <= i_upperShadRatio * candleRange(0)
     and bodySize(0) > 0

pHammer = hammerShape and trendDn1

// ── Hanging Man (ch. 4) ──────────────────────────────────────────────
pHangingMan = hammerShape and trendUp1

// ── Engulfing (ch. 5) ────────────────────────────────────────────────
pEngulfBull = isBearish(1) and isBullish(0)
     and bodyBot(0) < bodyBot(1) and bodyTop(0) > bodyTop(1)
     and trendDn2
pEngulfBear = isBullish(1) and isBearish(0)
     and bodyBot(0) < bodyBot(1) and bodyTop(0) > bodyTop(1)
     and trendUp2

// ── Dark Cloud Cover (ch. 5) ─────────────────────────────────────────
pDarkCloud = isBullish(1) and isBearish(0) and isLongBody(1)
     and open[0] > high[1]
     and close[0] < bodyBot(1) + (1 - i_penetration) * bodySize(1)
     and close[0] > bodyBot(1)
     and trendUp2

// ── Piercing Pattern (ch. 5) ────────────────────────────────────────
pPiercing = isBearish(1) and isBullish(0) and isLongBody(1)
     and open[0] < low[1]
     and close[0] > bodyBot(1) + i_penetration * bodySize(1)
     and close[0] < bodyTop(1)
     and trendDn2

// ── Inverted Hammer (ch. 6) ─────────────────────────────────────────
invertedShape = candleRange(0) > 0
     and upperShad(0) >= i_shadowMult * bodySize(0)
     and lowerShad(0) <= i_upperShadRatio * candleRange(0)
     and bodySize(0) > 0

pInvHammer = invertedShape and trendDn1

// ── Shooting Star (ch. 6) ───────────────────────────────────────────
pShootingStar = invertedShape and trendUp1

// ── Morning Star (ch. 9) ────────────────────────────────────────────
pMorningStar = trendDn3 and isLongBody(2) and isBearish(2)
     and isSmallBody(1)
     and bodyTop(1) < bodyBot(2)  // gap down
     and isLongBody(0) and isBullish(0)
     and close[0] > bodyBot(2) + i_penetration * bodySize(2)

// ── Evening Star (ch. 9) ────────────────────────────────────────────
pEveningStar = trendUp3 and isLongBody(2) and isBullish(2)
     and isSmallBody(1)
     and bodyBot(1) > bodyTop(2)  // gap up
     and isLongBody(0) and isBearish(0)
     and close[0] < bodyTop(2) - i_penetration * bodySize(2)

// ── Morning Doji Star (ch. 9) ───────────────────────────────────────
pMorningDojiStar = trendDn3 and isLongBody(2) and isBearish(2)
     and isDoji(1)
     and bodyTop(1) < bodyBot(2)
     and isLongBody(0) and isBullish(0)
     and close[0] > bodyBot(2) + i_penetration * bodySize(2)

// ── Evening Doji Star (ch. 9) ───────────────────────────────────────
pEveningDojiStar = trendUp3 and isLongBody(2) and isBullish(2)
     and isDoji(1)
     and bodyBot(1) > bodyTop(2)
     and isLongBody(0) and isBearish(0)
     and close[0] < bodyTop(2) - i_penetration * bodySize(2)

// ── Doji at Top (ch. 7–8) ───────────────────────────────────────────
pDojiTop = isDoji(0) and trendUp1

// ── Doji at Bottom (ch. 7–8) ────────────────────────────────────────
pDojiBot = isDoji(0) and trendDn1

// ── Long-legged Doji (ch. 7–8) ──────────────────────────────────────
pLongLegDoji = isDoji(0) and candleRange(0) > 0
     and upperShad(0) >= i_llDojiShadow * candleRange(0)
     and lowerShad(0) >= i_llDojiShadow * candleRange(0)

pLongLegBull = pLongLegDoji and trendDn1
pLongLegBear = pLongLegDoji and trendUp1

// ── Rickshaw Man (ch. 7–8) ──────────────────────────────────────────
pRickshaw = pLongLegDoji and candleRange(0) > 0
midBody  = (bodyTop(0) + bodyBot(0)) / 2
midRange = (high[0] + low[0]) / 2
pRickshawMan = pRickshaw
     and math.abs(midBody - midRange) <= i_rikCenter * candleRange(0)

pRickBull = pRickshawMan and trendDn1
pRickBear = pRickshawMan and trendUp1

// ── Gravestone Doji (ch. 7–8) ───────────────────────────────────────
pGravestone = isDoji(0) and candleRange(0) > 0
     and lowerShad(0) <= i_graveLower * candleRange(0)
     and upperShad(0) >= i_graveUpper * candleRange(0)
     and trendUp1

// ── Tri-star (ch. 7–8) ──────────────────────────────────────────────
pTriStarBear = isDoji(2) and isDoji(1) and isDoji(0) and trendUp3
     and bodyTop(1) > bodyTop(2) and bodyTop(1) > bodyTop(0)
pTriStarBull = isDoji(2) and isDoji(1) and isDoji(0) and trendDn3
     and bodyBot(1) < bodyBot(2) and bodyBot(1) < bodyBot(0)

// ── Harami (ch. 10) ─────────────────────────────────────────────────
pHaramiBull = isBearish(1) and isLongBody(1) and isBullish(0)
     and bodyTop(0) < bodyTop(1) and bodyBot(0) > bodyBot(1)
     and trendDn2
pHaramiBear = isBullish(1) and isLongBody(1) and isBearish(0)
     and bodyTop(0) < bodyTop(1) and bodyBot(0) > bodyBot(1)
     and trendUp2

// ── Harami Cross (ch. 10) ───────────────────────────────────────────
pHaramiXBull = isBearish(1) and isLongBody(1) and isDoji(0)
     and bodyTop(0) < bodyTop(1) and bodyBot(0) > bodyBot(1)
     and trendDn2
pHaramiXBear = isBullish(1) and isLongBody(1) and isDoji(0)
     and bodyTop(0) < bodyTop(1) and bodyBot(0) > bodyBot(1)
     and trendUp2

// ── Tweezers Top (ch. 11) ───────────────────────────────────────────
pTweezersTop = math.abs(high[0] - high[1]) <= i_matchTol * high[1]
     and isBullish(1) and isBearish(0)
     and trendUp2

// ── Tweezers Bottom (ch. 11) ────────────────────────────────────────
pTweezersBot = math.abs(low[0] - low[1]) <= i_matchTol * low[1]
     and isBearish(1) and isBullish(0)
     and trendDn2

// ── Belt Hold (ch. 11) ──────────────────────────────────────────────
pBeltBull = isBullish(0) and isLongBody(0)
     and lowerShad(0) <= i_beltShadow * candleRange(0)
     and trendDn1
pBeltBear = isBearish(0) and isLongBody(0)
     and upperShad(0) <= i_beltShadow * candleRange(0)
     and trendUp1

// ── Upside Gap Two Crows (ch. 11) ───────────────────────────────────
pUGTwoCrows = trendUp3 and isBullish(2) and isLongBody(2)
     and isBearish(1) and open[1] > close[2]   // gap up
     and isBearish(0)
     and open[0] > open[1] and close[0] < close[1]
     and close[0] > close[2]

// ── Three Black Crows (ch. 12) ──────────────────────────────────────
pThreeBlackCrows = trendUp3
     and isBearish(2) and isLongBody(2) and lowerShad(2) <= i_crowsShadow * candleRange(2)
     and isBearish(1) and isLongBody(1) and lowerShad(1) <= i_crowsShadow * candleRange(1)
     and isBearish(0) and isLongBody(0) and lowerShad(0) <= i_crowsShadow * candleRange(0)
     and close[1] < close[2] and close[0] < close[1]
     and open[1] < open[2] and open[1] > close[2]
     and open[0] < open[1] and open[0] > close[1]

// ── Three White Soldiers (ch. 14) ───────────────────────────────────
pThreeWhiteSoldiers = trendDn3
     and isBullish(2) and isLongBody(2) and upperShad(2) <= i_crowsShadow * candleRange(2)
     and isBullish(1) and isLongBody(1) and upperShad(1) <= i_crowsShadow * candleRange(1)
     and isBullish(0) and isLongBody(0) and upperShad(0) <= i_crowsShadow * candleRange(0)
     and close[1] > close[2] and close[0] > close[1]
     and open[1] > open[2] and open[1] < close[2]
     and open[0] > open[1] and open[0] < close[1]

// ── Counterattack Lines (ch. 12) ────────────────────────────────────
pCounterBull = isBearish(1) and isLongBody(1)
     and isBullish(0) and isLongBody(0)
     and math.abs(close[0] - close[1]) <= i_matchTol * close[1]
     and trendDn2
pCounterBear = isBullish(1) and isLongBody(1)
     and isBearish(0) and isLongBody(0)
     and math.abs(close[0] - close[1]) <= i_matchTol * close[1]
     and trendUp2

// ── Separating Lines (ch. 14) ───────────────────────────────────────
pSepBull = isBearish(1)
     and isBullish(0) and isLongBody(0)
     and math.abs(open[0] - open[1]) <= i_matchTol * open[1]
     and trendUp2
pSepBear = isBullish(1)
     and isBearish(0) and isLongBody(0)
     and math.abs(open[0] - open[1]) <= i_matchTol * open[1]
     and trendDn2

// ── Window Up / Down (ch. 13) ───────────────────────────────────────
pWindowUp   = low[0] > high[1] and trendUp2
pWindowDown = high[0] < low[1] and trendDn2

// ── Rising Three Methods (ch. 14) ───────────────────────────────────
pRising3 = isBullish(4) and isLongBody(4)
     and isSmallBody(3) and isSmallBody(2) and isSmallBody(1)
     and isBullish(0) and isLongBody(0)
     and close[0] > close[4]
     and low[3] > low[4] and low[2] > low[4] and low[1] > low[4]
     and high[3] < high[4] and high[2] < high[4] and high[1] < high[4]

// ── Falling Three Methods (ch. 14) ──────────────────────────────────
pFalling3 = isBearish(4) and isLongBody(4)
     and isSmallBody(3) and isSmallBody(2) and isSmallBody(1)
     and isBearish(0) and isLongBody(0)
     and close[0] < close[4]
     and high[3] < high[4] and high[2] < high[4] and high[1] < high[4]
     and low[3] > low[4] and low[2] > low[4] and low[1] > low[4]

// ── Three Mountains (ch. 12) ────────────────────────────────────────
// Precompute pivot series at global scope (Pine requires ta.* at top level)
_phForMt = ta.pivothigh(high, 2, 2)
_plForMt = ta.pivotlow (low,  2, 2)

// Simplified: three pivot highs within lookback with similar values
pThreeMountains = false
if bar_index > i_mtRiverLB
    var float[] recentPH = array.new_float(0)
    array.clear(recentPH)
    for k = 1 to i_mtRiverLB
        if not na(_phForMt[k])
            array.push(recentPH, high[k + 2])
    if array.size(recentPH) >= 3
        h1 = array.get(recentPH, 0)
        h2 = array.get(recentPH, 1)
        h3 = array.get(recentPH, 2)
        meanH = (h1 + h2 + h3) / 3
        if math.max(h1, h2, h3) - math.min(h1, h2, h3) <= i_mtRiverTol * meanH
            pThreeMountains := isBearish(0) and trendUp1

// ── Three Rivers (ch. 12) ───────────────────────────────────────────
pThreeRivers = false
if bar_index > i_mtRiverLB
    var float[] recentPL = array.new_float(0)
    array.clear(recentPL)
    for k = 1 to i_mtRiverLB
        if not na(_plForMt[k])
            array.push(recentPL, low[k + 2])
    if array.size(recentPL) >= 3
        l1 = array.get(recentPL, 0)
        l2 = array.get(recentPL, 1)
        l3 = array.get(recentPL, 2)
        meanL = (l1 + l2 + l3) / 3
        if math.max(l1, l2, l3) - math.min(l1, l2, l3) <= i_mtRiverTol * meanL
            pThreeRivers := isBullish(0) and trendDn1

// ── Tower Top (ch. 12) ──────────────────────────────────────────────
pTowerTop = false
if bar_index >= i_multiBarWin
    if isLongBody(i_multiBarWin - 1) and isBullish(i_multiBarWin - 1)
         and isLongBody(0) and isBearish(0)
        allSmall = true
        for k = 1 to i_multiBarWin - 2
            if not isSmallBody(k)
                allSmall := false
        pTowerTop := allSmall

// ── Tower Bottom (ch. 12) ───────────────────────────────────────────
pTowerBot = false
if bar_index >= i_multiBarWin
    if isLongBody(i_multiBarWin - 1) and isBearish(i_multiBarWin - 1)
         and isLongBody(0) and isBullish(0)
        allSmall2 = true
        for k = 1 to i_multiBarWin - 2
            if not isSmallBody(k)
                allSmall2 := false
        pTowerBot := allSmall2

// ── Dumpling Top (ch. 12) ───────────────────────────────────────────
pDumplingTop = false
if bar_index >= i_multiBarWin
    nSmall = 0
    for k = 1 to i_multiBarWin - 1
        if isSmallBody(k)
            nSmall += 1
    pDumplingTop := nSmall >= (i_multiBarWin - 2)
         and isBearish(0) and isLongBody(0)
         and trendUpMB

// ── Fry Pan Bottom (ch. 12) ─────────────────────────────────────────
pFryPanBot = false
if bar_index >= i_multiBarWin
    nSmall3 = 0
    for k = 1 to i_multiBarWin - 1
        if isSmallBody(k)
            nSmall3 += 1
    pFryPanBot := nSmall3 >= (i_multiBarWin - 2)
         and isBullish(0) and isLongBody(0)
         and trendDnMB


// ═══════════════════════════════════════════════════════════════════════════
// CONFIRMATION (ch. 4, 6, 7–8)
// ═══════════════════════════════════════════════════════════════════════════

// Hanging man: confirmed when next bar closes below body
confHangingMan    = pHangingMan[1]    and close[0] < bodyBot(1)
// Shooting star: confirmed when next bar closes below body
confShootingStar  = pShootingStar[1]  and close[0] < bodyBot(1)
// Inverted hammer: confirmed when next bar closes above body
confInvHammer     = pInvHammer[1]     and close[0] > bodyTop(1)
// Doji at top: confirmed by bearish candle
confDojiTop       = pDojiTop[1]       and isBearish(0)
// Doji at bottom: confirmed by bullish candle
confDojiBot       = pDojiBot[1]       and isBullish(0)
// Gravestone: confirmed by bearish candle
confGravestone    = pGravestone[1]    and isBearish(0)


// ═══════════════════════════════════════════════════════════════════════════
// SCORING
// ═══════════════════════════════════════════════════════════════════════════
// Composite: 50% shape + 20% volume + 30% trend strength (0.0–1.0)

// Volume score
volAvg   = ta.sma(volume, i_volWindow)
volScore = volAvg > 0 and not na(volume) ? math.min(volume / volAvg, 2.0) / 2.0 : 0.5

// Trend strength score
trendSlope    = regSlope(close, i_trendScoreLB)
atrVal        = ta.atr(i_trendScoreLB)
trendStrScore = atrVal > 0 ? math.min(math.abs(trendSlope) / atrVal, 1.0) : 0.0

// Shape score helpers
hammerShapeScore() =>
    bs = bodySize(0)
    ls = lowerShad(0)
    ratio = bs > 0 ? ls / bs : 0.0
    math.min(math.max((ratio - 2.0) / 4.0, 0.0), 1.0)

invertedShapeScore() =>
    bs = bodySize(0)
    us = upperShad(0)
    ratio = bs > 0 ? us / bs : 0.0
    math.min(math.max((ratio - 2.0) / 4.0, 0.0), 1.0)

engulfShapeScore() =>
    currBody = bodySize(0)
    prevBody = bodySize(1)
    ratio = prevBody > 0 ? currBody / prevBody : 1.0
    math.min(math.max((ratio - 1.0) / 4.0, 0.0), 1.0)

dojiShapeScore() =>
    rng = candleRange(0)
    bs  = bodySize(0)
    rng > 0 ? math.max(1.0 - bs / (i_dojiThr * rng), 0.0) : 0.5

composite(shape) =>
    math.min(math.max(0.5 * shape + 0.2 * volScore + 0.3 * trendStrScore, 0.0), 1.0)


// ═══════════════════════════════════════════════════════════════════════════
// COLLECT SIGNALS INTO PER-BAR LABELS
// ═══════════════════════════════════════════════════════════════════════════

// Build label text for current bar.
var string bullLabel = ""
var string bearLabel = ""
var float  bullScore = 0.0
var float  bearScore = 0.0
var int    bullCount = 0
var int    bearCount = 0
var bool   bullAllPending = true
var bool   bearAllPending = true

bullLabel := ""
bearLabel := ""
bullScore := 0.0
bearScore := 0.0
bullCount := 0
bearCount := 0
bullAllPending := true
bearAllPending := true

addBull(name, score) =>
    [bullLabel + (bullCount > 0 ? "\n" : "") + name,
     math.max(bullScore, score), bullCount + 1]

addBear(name, score) =>
    [bearLabel + (bearCount > 0 ? "\n" : "") + name,
     math.max(bearScore, score), bearCount + 1]

// ── Bullish patterns ─────────────────────────────────────────────────
if pHammer
    [l, s, c] = addBull("hammer", composite(hammerShapeScore()))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pEngulfBull
    [l, s, c] = addBull("engulfing", composite(engulfShapeScore()))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pPiercing
    [l, s, c] = addBull("piercing", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pInvHammer
    s = composite(invertedShapeScore())
    conf = i_showConf ? " (pending)" : ""
    [l, sc, ct] = addBull("inv hammer" + conf, s)
    bullLabel := l, bullScore := sc, bullCount := ct
if confInvHammer
    [l, s, c] = addBull("✓ inv hammer", composite(invertedShapeScore()[1]))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pMorningStar
    [l, s, c] = addBull("morning star", composite(0.6))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pMorningDojiStar
    [l, s, c] = addBull("morning doji star", composite(0.7))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pDojiBot
    s = composite(dojiShapeScore())
    conf = i_showConf ? " (pending)" : ""
    [l, sc, ct] = addBull("doji bottom" + conf, s)
    bullLabel := l, bullScore := sc, bullCount := ct
if confDojiBot
    [l, s, c] = addBull("✓ doji bottom", composite(dojiShapeScore()[1]))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pLongLegBull
    [l, s, c] = addBull("long-leg doji", composite(dojiShapeScore()))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pRickBull
    [l, s, c] = addBull("rickshaw man", composite(dojiShapeScore()))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pTriStarBull
    [l, s, c] = addBull("tri-star", composite(0.7))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pHaramiBull
    [l, s, c] = addBull("harami", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pHaramiXBull
    [l, s, c] = addBull("harami cross", composite(0.6))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pTweezersBot
    [l, s, c] = addBull("tweezers bottom", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pBeltBull
    [l, s, c] = addBull("belt hold", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pCounterBull
    [l, s, c] = addBull("counterattack", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pSepBull
    [l, s, c] = addBull("separating", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pWindowUp
    [l, s, c] = addBull("window up", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pRising3
    [l, s, c] = addBull("rising 3 methods", composite(0.6))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pThreeWhiteSoldiers
    [l, s, c] = addBull("3 white soldiers", composite(0.7))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pThreeRivers
    [l, s, c] = addBull("three rivers", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pFryPanBot
    [l, s, c] = addBull("fry pan bottom", composite(0.5))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false
if pTowerBot
    [l, s, c] = addBull("tower bottom", composite(0.6))
    bullLabel := l, bullScore := s, bullCount := c, bullAllPending := false

// ── Bearish patterns ─────────────────────────────────────────────────
if pHangingMan
    s = composite(hammerShapeScore())
    conf = i_showConf ? " (pending)" : ""
    [l, sc, ct] = addBear("hanging man" + conf, s)
    bearLabel := l, bearScore := sc, bearCount := ct
if confHangingMan
    [l, s, c] = addBear("✓ hanging man", composite(hammerShapeScore()[1]))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pEngulfBear
    [l, s, c] = addBear("engulfing", composite(engulfShapeScore()))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pDarkCloud
    [l, s, c] = addBear("dark cloud", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pShootingStar
    s = composite(invertedShapeScore())
    conf = i_showConf ? " (pending)" : ""
    [l, sc, ct] = addBear("shooting star" + conf, s)
    bearLabel := l, bearScore := sc, bearCount := ct
if confShootingStar
    [l, s, c] = addBear("✓ shooting star", composite(invertedShapeScore()[1]))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pEveningStar
    [l, s, c] = addBear("evening star", composite(0.6))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pEveningDojiStar
    [l, s, c] = addBear("evening doji star", composite(0.7))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pDojiTop
    s = composite(dojiShapeScore())
    conf = i_showConf ? " (pending)" : ""
    [l, sc, ct] = addBear("doji top" + conf, s)
    bearLabel := l, bearScore := sc, bearCount := ct
if confDojiTop
    [l, s, c] = addBear("✓ doji top", composite(dojiShapeScore()[1]))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pGravestone
    s = composite(dojiShapeScore())
    conf = i_showConf ? " (pending)" : ""
    [l, sc, ct] = addBear("gravestone" + conf, s)
    bearLabel := l, bearScore := sc, bearCount := ct
if confGravestone
    [l, s, c] = addBear("✓ gravestone", composite(dojiShapeScore()[1]))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pLongLegBear
    [l, s, c] = addBear("long-leg doji", composite(dojiShapeScore()))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pRickBear
    [l, s, c] = addBear("rickshaw man", composite(dojiShapeScore()))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pTriStarBear
    [l, s, c] = addBear("tri-star", composite(0.7))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pHaramiBear
    [l, s, c] = addBear("harami", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pHaramiXBear
    [l, s, c] = addBear("harami cross", composite(0.6))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pTweezersTop
    [l, s, c] = addBear("tweezers top", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pBeltBear
    [l, s, c] = addBear("belt hold", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pUGTwoCrows
    [l, s, c] = addBear("upside gap 2 crows", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pThreeBlackCrows
    [l, s, c] = addBear("3 black crows", composite(0.7))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pCounterBear
    [l, s, c] = addBear("counterattack", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pSepBear
    [l, s, c] = addBear("separating", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pWindowDown
    [l, s, c] = addBear("window down", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pFalling3
    [l, s, c] = addBear("falling 3 methods", composite(0.6))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pThreeMountains
    [l, s, c] = addBear("three mountains", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pDumplingTop
    [l, s, c] = addBear("dumpling top", composite(0.5))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false
if pTowerTop
    [l, s, c] = addBear("tower top", composite(0.6))
    bearLabel := l, bearScore := s, bearCount := c, bearAllPending := false


// ═══════════════════════════════════════════════════════════════════════════
// PLOTTING
// ═══════════════════════════════════════════════════════════════════════════

// ── Pivots — label-based with retroactive dedup ─────────────────────
// Order-1 pivots render immediately. Higher-order pivots fire later
// (when the next lower-order pivot confirms them) and retroactively
// delete the lower-order label at the same bar.

// Arrays track [pivot_bar_index, label_id] for recent pivot labels.
var int[]   pvhBars   = array.new_int(0)
var label[] pvhLabels = array.new_label(0)
var int[]   pvlBars   = array.new_int(0)
var label[] pvlLabels = array.new_label(0)

// Pivots use built-in triangle label styles. The triangle tip anchors at
// the y coordinate (bar high/low), so it sits right at the bar tip with
// consistent visual spacing regardless of zoom.
_placePivotHigh(int pivotBar, color clr, string sz) =>
    if i_showPivots
        if array.size(pvhBars) > 0
            for idx = array.size(pvhBars) - 1 to 0
                if array.get(pvhBars, idx) == pivotBar
                    label.delete(array.get(pvhLabels, idx))
                    array.remove(pvhBars, idx)
                    array.remove(pvhLabels, idx)
        lbl = label.new(pivotBar, na, "",
             style=label.style_triangledown, color=clr,
             size=sz, yloc=yloc.abovebar)
        array.push(pvhBars, pivotBar)
        array.push(pvhLabels, lbl)
        if array.size(pvhBars) > 200
            array.shift(pvhBars)
            label.delete(array.shift(pvhLabels))

_placePivotLow(int pivotBar, color clr, string sz) =>
    if i_showPivots
        if array.size(pvlBars) > 0
            for idx = array.size(pvlBars) - 1 to 0
                if array.get(pvlBars, idx) == pivotBar
                    label.delete(array.get(pvlLabels, idx))
                    array.remove(pvlBars, idx)
                    array.remove(pvlLabels, idx)
        lbl = label.new(pivotBar, na, "",
             style=label.style_triangleup, color=clr,
             size=sz, yloc=yloc.belowbar)
        array.push(pvlBars, pivotBar)
        array.push(pvlLabels, lbl)
        if array.size(pvlBars) > 200
            array.shift(pvlBars)
            label.delete(array.shift(pvlLabels))

// Order 1 fires first — may be superseded later by order 2 or 3
if not na(ph1)
    _placePivotHigh(ph1Bar, color.new(color.red, 50), size.auto)
if not na(pl1)
    _placePivotLow(pl1Bar, color.new(color.green, 50), size.auto)

// Order 2 fires when next order-1 confirms — deletes order-1 label at same bar
if newPH2
    _placePivotHigh(ph2Bar, color.new(color.red, 10), size.tiny)
if newPL2
    _placePivotLow(pl2Bar, color.new(color.green, 10), size.tiny)

// Order 3 fires when next order-2 confirms — deletes order-2 label at same bar
if newPH3
    _placePivotHigh(ph3Bar, color.new(color.red, 10), size.normal)
if newPL3
    _placePivotLow(pl3Bar, color.new(color.green, 10), size.normal)

// ── Pattern labels ───────────────────────────────────────────────────
// Pattern text with background fill so it renders in front of candles.
if i_showPatterns and bullCount > 0
    clr = bullAllPending ? color.gray : color.blue
    label.new(bar_index, na, bullLabel,
         style=label.style_label_up, color=color.new(clr, 85),
         textcolor=clr, size=size.tiny, yloc=yloc.belowbar)

if i_showPatterns and bearCount > 0
    clr = bearAllPending ? color.gray : color.orange
    label.new(bar_index, na, bearLabel,
         style=label.style_label_down, color=color.new(clr, 85),
         textcolor=clr, size=size.tiny, yloc=yloc.abovebar)

// ── Multi-scale trend table ──────────────────────────────────────────
trendColor(val) => val == 1 ? color.green : val == -1 ? color.red : color.gray
trendText(val)  => val == 1 ? "UP" : val == -1 ? "DOWN" : "—"

var table trendTable = table.new(position.top_right, 2, 4,
     bgcolor=color.new(color.gray, 85), border_width=1)

if i_showTable
    table.cell(trendTable, 0, 0, "Micro",  text_color=color.white, text_size=size.small)
    table.cell(trendTable, 1, 0, trendText(microTrend),
         bgcolor=trendColor(microTrend), text_color=color.white, text_size=size.small)
    table.cell(trendTable, 0, 1, "Short",  text_color=color.white, text_size=size.small)
    table.cell(trendTable, 1, 1, trendText(shortTrend),
         bgcolor=trendColor(shortTrend), text_color=color.white, text_size=size.small)
    table.cell(trendTable, 0, 2, "Medium", text_color=color.white, text_size=size.small)
    table.cell(trendTable, 1, 2, trendText(mediumTrend),
         bgcolor=trendColor(mediumTrend), text_color=color.white, text_size=size.small)
    table.cell(trendTable, 0, 3, "Long",   text_color=color.white, text_size=size.small)
    table.cell(trendTable, 1, 3, trendText(longTrend),
         bgcolor=trendColor(longTrend), text_color=color.white, text_size=size.small)

// ── Alerts ───────────────────────────────────────────────────────────
alertcondition(bullCount > 0, title="Bullish Pattern", message="Bullish candlestick pattern detected")
alertcondition(bearCount > 0, title="Bearish Pattern", message="Bearish candlestick pattern detected")
alertcondition(confHangingMan or confShootingStar or confGravestone,
     title="Bearish Confirmed", message="Bearish pattern confirmed")
alertcondition(confInvHammer or confDojiBot,
     title="Bullish Confirmed", message="Bullish pattern confirmed")
